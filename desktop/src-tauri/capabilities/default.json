{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for pet and login windows",
  "windows": ["pet", "pet-*", "panel-*", "setup", "login"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "opener:default",
    "notification:default",
    "deep-link:default"
  ]
}
