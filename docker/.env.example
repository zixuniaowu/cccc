# CCCC Docker Compose Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# After first launch, create an Admin Access Token in Settings > Web Access before exposing the port beyond localhost.

# Host port is published to 127.0.0.1 by default in docker-compose.yml.
# Web UI port (default: 8848)
# CCCC_PORT=8848

# Workspace path to mount into container
# WORKSPACE_PATH=/path/to/your/projects

# AI agent API keys (at least one required)
# ANTHROPIC_AUTH_TOKEN=sk-ant-xxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# GEMINI_API_KEY=xxx

# Build-time proxy (for networks that require a proxy)
# HTTP_PROXY=http://proxy:port
# HTTPS_PROXY=http://proxy:port
